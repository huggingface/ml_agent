# Copy this file to .env for local development.
# Leave unused values empty or comment them out.

# ---------------------------------------------------------------------------
# LLM provider keys
# ---------------------------------------------------------------------------
# Anthropic direct models, e.g. anthropic/claude-opus-4-6
ANTHROPIC_API_KEY=

# OpenAI direct models, e.g. openai/gpt-5.5
OPENAI_API_KEY=

# Z.AI direct models, e.g. zai/glm-5.1
# The code uses https://api.z.ai/api/paas/v4/ automatically.
ZAI_API_KEY=

# Legacy aliases accepted for Z.AI / GLM if ZAI_API_KEY is not set.
ZHIPUAI_API_KEY=
GLM_API_KEY=

# Hugging Face token for Hub access, Jobs, session uploads, and HF Router models.
HF_TOKEN=

# Optional shared HF Router inference token for hosted deployments.
INFERENCE_TOKEN=
HF_BILL_TO=smolagents

# GitHub tools.
GITHUB_TOKEN=

# AWS Bedrock, used by the default production Claude model.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ---------------------------------------------------------------------------
# Model defaults
# ---------------------------------------------------------------------------
# The web backend defaults to Bedrock Claude unless this is set.
# For local Anthropic direct usage:
# ML_INTERN_CLAUDE_MODEL_ID=anthropic/claude-opus-4-6
ML_INTERN_CLAUDE_MODEL_ID=

# Optional CLI config override.
ML_INTERN_CLI_CONFIG=

# ---------------------------------------------------------------------------
# Backend and auth
# ---------------------------------------------------------------------------
PORT=7860

# Empty OAUTH_CLIENT_ID means dev auth bypass is enabled.
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OPENID_PROVIDER_URL=https://huggingface.co
SPACE_HOST=
HF_EMPLOYEE_ORG=huggingface

# Optional MongoDB-backed session persistence.
MONGODB_URI=
MONGODB_DB=ml-intern

# Premium-model quota knobs.
CLAUDE_FREE_DAILY=1
CLAUDE_PRO_DAILY=20

# ---------------------------------------------------------------------------
# Session uploads and KPI rollups
# ---------------------------------------------------------------------------
HF_ADMIN_TOKEN=
HF_SESSION_UPLOAD_TOKEN=
HF_KPI_WRITE_TOKEN=
KPI_SOURCE_REPO=smolagents/ml-intern-sessions
KPI_TARGET_REPO=smolagents/ml-intern-kpis
ML_INTERN_KPIS_DISABLED=

# ---------------------------------------------------------------------------
# Optional integrations
# ---------------------------------------------------------------------------
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=
SLACK_CHANNEL=
ML_INTERN_SLACK_NOTIFICATIONS=true
ML_INTERN_SLACK_DESTINATION=slack.default
ML_INTERN_SLACK_AUTO_EVENTS=approval_required,error,turn_complete
ML_INTERN_SLACK_ALLOW_AGENT_TOOL=true
ML_INTERN_SLACK_ALLOW_AUTO_EVENTS=true

# Optional Semantic Scholar API key for paper lookups.
S2_API_KEY=

# Optional sandbox and web-search overrides.
SANDBOX_API_TOKEN=
CLAWD_WEB_SEARCH_BASE_URL=https://html.duckduckgo.com/html/
